# Copy this file to .env.local and fill in your values from the Supabase dashboard
# Project Settings > API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# This is the shared password you and Sofia will use to log in
VITE_APP_PASSWORD=choose-a-strong-password-here
